#!/usr/bin/env bash
set -euo pipefail

PROXY_PIDS=()
PROXY_PORT=""

cleanup() {
  for pid in "${PROXY_PIDS[@]}"; do
    kill "${pid}" 2>/dev/null || true
    wait "${pid}" 2>/dev/null || true
  done
}

trap cleanup EXIT

SQL_FILE="${HOME}/.psql/queries/btree_reindex_candidates.sql"
INPUT_TARGETS=()
TARGETS=()

check_gcp_auth() {
  if [ ! -f ~/.config/gcloud/access_tokens.db ]; then
    gcloud auth login --update-adc
    return
  fi

  exit_code=$(
    set +e

    output=$(expect << 'EOF'
      spawn gcloud auth print-identity-token
      expect {
        "Reauthentication required." { exit 4 }
      }

      foreach {pid spawnid os_error_flag exit_status} [wait] break
      exit $exit_status
EOF
    )

    echo $?
  )

  if [ $exit_code -ne 0 ]; then
      gcloud auth login --update-adc
  fi
}

log() {
  printf '%s\n' "$*" >&2
}

help() {
  echo "Run index_reindex_candidates.sql against production databases."
  echo ""
  echo "Usage: index_reindex_candidates_ampledash [<connection-name>|<database> ...]"
  echo "       index_reindex_candidates_ampledash < targets.txt"
  echo ""
  echo "Targets: one per argument or stdin line, as <connection-name>|<database>."
  echo "Stdin lines may also use whitespace: <connection-name> <database>."
  echo "Blank stdin lines and lines starting with # are ignored."
  echo ""
  echo "Example:"
  echo "  index_reindex_candidates_ampledash 'connection-name|database_name'"
  echo ""
  echo "Options:"
  echo "  -h, --help  Show this help"
  echo ""
  echo "Output: CSV: database,tbl,idx,bloat_size_pretty,bloat_pct,real_size"
  exit "${1:-1}"
}

add_target() {
  local target="$1"
  local connection_name=""
  local db_name=""
  local extra=""

  if [[ "${target}" =~ ^[[:space:]]*$ ]] || [[ "${target}" =~ ^[[:space:]]*# ]]; then
    return
  fi

  if [[ "${target}" = *"|"* ]]; then
    IFS='|' read -r connection_name db_name extra <<< "${target}"
  else
    read -r connection_name db_name extra <<< "${target}"
  fi

  if [ -z "${connection_name}" ] || [ -z "${db_name}" ] || [ -n "${extra}" ]; then
    echo "Error: invalid target '${target}'" >&2
    echo "Expected: <connection-name>|<database> or <connection-name> <database>" >&2
    exit 1
  fi

  TARGETS+=("${connection_name}|${db_name}")
}

read_stdin_targets() {
  local target

  while IFS= read -r target; do
    add_target "${target}"
  done
}

get_port_for_connection() {
  local connection_name="$1"
  local hash
  hash=$(echo -n "$connection_name" | cksum | cut -d' ' -f1)
  local port=$((12000 + (hash % 1000)))
  echo "$port"
}

wait_for_port() {
  local port="$1"
  local attempts=60

  for _ in $(seq 1 "${attempts}"); do
    if nc -z 127.0.0.1 "${port}" 2>/dev/null; then
      return 0
    fi
    sleep 0.5
  done

  echo "Error: cloud-sql-proxy did not become ready on port ${port}" >&2
  return 1
}

ensure_proxy() {
  local connection_name="$1"
  local port
  port=$(get_port_for_connection "${connection_name}")

  if [ -n "$(pgrep -xf "cloud-sql-proxy --auto-iam-authn --port ${port} ${connection_name}" || true)" ]; then
    log "Using existing cloud-sql-proxy on port ${port} for ${connection_name}"
    wait_for_port "${port}"
    PROXY_PORT="${port}"
    return
  fi

  log "Starting cloud-sql-proxy on port ${port} for ${connection_name}..."
  cloud-sql-proxy --auto-iam-authn --port "${port}" "${connection_name}" >&2 &
  PROXY_PIDS+=("$!")
  wait_for_port "${port}"
  PROXY_PORT="${port}"
}

run_query() {
  local db_name="$1"
  local label="$2"
  local port="$3"
  local psql_username="$4"
  local psql_conn="host=127.0.0.1 port=${port} sslmode=disable dbname=${db_name} user=${psql_username}"
  local psql_base_args=(
    --no-psqlrc
    --pset=pager=off
    -q
    -t
    -v ON_ERROR_STOP=1
  )

  log "Running query on ${label} (can take several minutes on large databases)..."

  PGOPTIONS='-c application_name=index_reindex_candidates' \
    psql --csv "${psql_base_args[@]}" "${psql_conn}" -f "${SQL_FILE}" \
    | awk -v db="${label}" '
        BEGIN { FS = "," }
        function unquote(value) {
          if (substr(value, 1, 1) == "\"" && substr(value, length(value), 1) == "\"")
            return substr(value, 2, length(value) - 2)
          return value
        }
        NF >= 10 {
          printf "%s,%s,%s,%s,%s,%s\n", db, unquote($3), unquote($4), unquote($9), unquote($10), unquote($5)
        }'
}

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      help 0
      ;;
    --*)
      echo "Unknown option: $1" >&2
      help
      ;;
    *)
      INPUT_TARGETS+=("$1")
      ;;
  esac
  shift
done

if [ ! -f "${SQL_FILE}" ]; then
  echo "Error: SQL file '${SQL_FILE}' not found" >&2
  exit 1
fi

if [ "${#INPUT_TARGETS[@]}" -gt 0 ]; then
  for target in "${INPUT_TARGETS[@]}"; do
    add_target "${target}"
  done
elif [ -t 0 ]; then
  echo "Error: no targets provided" >&2
  help
else
  read_stdin_targets
fi

if [ "${#TARGETS[@]}" -eq 0 ]; then
  echo "Error: no targets provided" >&2
  exit 1
fi

log "Checking GCP auth..."
check_gcp_auth
PSQL_USERNAME=$(gcloud auth list --filter=status:ACTIVE --format="value(account)")
log "Using ${PSQL_USERNAME}"

echo "database,tbl,idx,bloat_size_pretty,bloat_pct,real_size"

for target in "${TARGETS[@]}"; do
  IFS='|' read -r connection_name db_name <<< "${target}"
  ensure_proxy "${connection_name}"
  run_query "${db_name}" "${db_name}" "${PROXY_PORT}" "${PSQL_USERNAME}"
done

log "Done."
