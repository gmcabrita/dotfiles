{
  "$schema": "https://opencode.ai/config.json",
  "theme": "carbonfox",
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh"
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh"
    },
    "general": {
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "model": "openai/gpt-5.4"
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    },
    "external_directory": {
      "/Users/gmcabrita/Developer/dotfiles/.config/opencode/*": "allow",
      "/Users/gmcabrita/.config/opencode/*": "allow"
    }
  },
  "autoupdate": "notify",
  "lsp": {
    "ruby-lsp": {
      "disabled": true
    }
  },
  "formatter": {
    "rubocop": {
      "disabled": true
    }
  }
}
