    )::text
    || '%)' as "Table Size",
    pg_size_pretty(index_bytes)
    || ' ('
    || round(
        100
        * index_bytes::numeric
        / nullif(
            sum(index_bytes) over (
                partition by (schema_name is null), left(table_name, 3) = '***'
            ),
