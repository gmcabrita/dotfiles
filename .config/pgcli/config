        - pg_indexes_size(c.oid)
        - coalesce(pg_total_relation_size(reltoastrelid), 0) as table_bytes
    from pg_class c
    left join pg_namespace n on n.oid = c.relnamespace
    where relkind = 'r' and nspname <> 'pg_catalog'
),

data2 as (
    select
        null::oid as oid,
        null as tblspace,
        null as schema_name,
