        sum(index_bytes) as index_bytes,
        sum(toast_bytes) as toast_bytes,
        sum(table_bytes) as table_bytes
    from data
    union all
    select
        null::oid as oid,
        null,
        null as schema_name,
        ' tablespace: ['
        || coalesce(tblspace, 'pg_default')
