[main]
smart_completion = True
auto_suggest = True
wider_completion_menu = False
always_use_single_connection = False
multi_line = True
multi_line_mode = psql
destructive_warning = drop, shutdown, delete, truncate, alter, update, unconditional_update
destructive_warning_restarts_connection = False
destructive_statements_require_transaction = False
expand = False
auto_expand = False
auto_retry_closed_connection = True
keyword_casing = lower
case_column_headers = True
history_file = default
timing = True
hide_named_query_text = True
show_bottom_toolbar = False
table_format = psql
syntax_style = default
vi = False
on_error = STOP
row_limit = 0
max_field_width =
less_chatty = True
verbose_errors = False
prompt = '\u@\d=\#\T '
min_num_menu_lines = 4
multiline_continuation_char = '·'
null_string = '[NULL]'
enable_pager = True
keyring = True
use_local_timezone = False

[colors]
output.header = "bold"

[named queries]
version = "select version();"
extensions = "select * from pg_available_extensions;"
autovacuum = """select
    relname,
    last_vacuum,
    last_autovacuum
from pg_stat_user_tables
where last_autovacuum is not null
order by last_autovacuum desc
;"""
autovacuum_order = """select
    relname,
    last_vacuum,
    last_autovacuum
from pg_stat_user_tables
where last_autovacuum is not null
order by
    case when lower('$1') = 'asc' then last_autovacuum end asc,
    case when lower('$1') = 'desc' then last_autovacuum end desc
;"""
cache_hit_ratio = """with stats as (
    select
        'tables' as kind,
        relname as table,
        sum(heap_blks_read) as blocks_read,
        sum(heap_blks_hit) as blocks_hit
    from pg_statio_user_tables
    where heap_blks_read > 0
    group by relname
    union all
    select
        'indices' as kind,
        relname as table,
        sum(idx_blks_read) as blocks_read,
        sum(idx_blks_hit) as blocks_hit
    from pg_statio_user_indexes
    where idx_blks_read > 0
    group by relname
)
select
    table,
    blocks_read,
    blocks_hit,
    round((blocks_hit / nullif((blocks_hit + blocks_read), 0)::numeric) * 100, 2) as ratio
from stats
where kind = lower('$1')
order by ratio desc
;"""
connection_counts = """with mode as (
    select lower('$1') as value
)
select
    case when mode.value = 'application' then application_name end as application_name,
    state,
    count(*)
from pg_stat_activity
cross join mode
where mode.value in ('application', 'state')
group by 1, state
order by count(*) desc
;"""
