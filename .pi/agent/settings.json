{
  "startup": {
    "model": "gpt-5.5",
    "provider": "openai",
    "thinkingLevel": "medium"
  },
  "enabledModels": ["openai-codex/gpt-5.5", "openai/gpt-5.5"],
  "enableInstallTelemetry": false,
  "hideThinkingBlock": true,
  "lastChangelogVersion": "999.999.999",
  "quietStartup": true,
  "theme": "light",
  "toolPolicy": {
    "all": {
      "*": "allow",
      ".*.vars": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "*.pem": "deny",
      ".npmrc": "deny",
      ".pypirc": "deny",
      "secrets/*": "deny",
      "**/secrets/*": "deny",
      ".aws/*": "deny",
      "**/.aws/*": "deny",
      ".ssh/*": "deny",
      "**/.ssh/*": "deny",
      ".gnupg/*": "deny",
      "**/.gnupg/*": "deny",
      "id_rsa": "deny",
      "id_rsa.*": "deny",
      "id_ed25519": "deny",
      "id_ed25519.*": "deny"
    }
  }
}
