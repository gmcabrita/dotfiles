{
  "//": "https://repoprompt.com/docs#s=workflows&ss=model-recommendations",
  "//": "https://cursor.com/evals",
  "packages": ["git:github.com/dmmulroy/pi-mcp", "npm:pi-anthropic-oauth"],
  "startup": {
    "model": "gpt-5.6-sol",
    "provider": "openai-codex-lb",
    "thinkingLevel": "high"
  },
  "enabledModels": [
    "openai-codex-lb/gpt-5.6-sol",
    "openai-codex-lb/gpt-5.6-terra",
    "openai-codex-lb/gpt-5.6-luna",
    "openai-codex/gpt-5.6-sol",
    "openai-codex/gpt-5.6-terra",
    "openai-codex/gpt-5.6-luna",
    "anthropic/claude-fable-5",
    "deepseek/deepseek-v4-pro",
    "deepseek/deepseek-v4-flash",
    "openrouter/anthropic/claude-fable-5",
    "openrouter/openai/gpt-5.6-sol-pro",
    "openrouter/deepseek/deepseek-v4-pro",
    "openrouter/deepseek/deepseek-v4-flash"
  ],
  "enableInstallTelemetry": false,
  "hideThinkingBlock": true,
  "lastChangelogVersion": "999.999.999",
  "quietStartup": true,
  "transport": "websocket-cached",
  "terminal": {
    "showTerminalProgress": true
  },
  "npmCommand": ["sfw", "npm"],
  "showCacheMissNotices": true,
  "theme": "light"
}
