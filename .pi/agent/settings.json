{
  "modelRecommendations": "https://repoprompt.com/docs#s=workflows&ss=model-recommendations",
  "startup": {
    "model": "gpt-5.5",
    "provider": "openai",
    "thinkingLevel": "high"
  },
  "review": {
    "model": "gpt-5.5",
    "provider": "openai",
    "thinkingLevel": "xhigh"
  },
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai/gpt-5.5",
    "cursor/composer-2.5",
    "deepseek/deepseek-v4-pro",
    "deepseek/deepseek-v4-flash"
  ],
  "enableInstallTelemetry": false,
  "hideThinkingBlock": true,
  "lastChangelogVersion": "999.999.999",
  "quietStartup": true,
  "transport": "websocket-cached",
  "terminal": {
    "showTerminalProgress": true
  },
  "npmCommand": ["sfw", "npm"],
  "packages": ["npm:@schultzp2020/pi-cursor"],
  "theme": "light",
  "toolPolicy": {
    "all": {
      "*": "allow",
      ".*.vars": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "*.pem": "deny",
      ".npmrc": "deny",
      ".pypirc": "deny",
      "secrets/*": "deny",
      "**/secrets/*": "deny",
      ".aws/*": "deny",
      "**/.aws/*": "deny",
      ".ssh/*": "deny",
      "**/.ssh/*": "deny",
      ".gnupg/*": "deny",
      "**/.gnupg/*": "deny",
      "id_rsa": "deny",
      "id_rsa.*": "deny",
      "id_ed25519": "deny",
      "id_ed25519.*": "deny"
    }
  }
}
