{
  "lastChangelogVersion": "0.60.0",
  "theme": "light",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "xhigh",
  "hideThinkingBlock": true,
  "quietStartup": true
  "toolPolicy": {
    "all": {
      "*": "allow",
      ".*.vars": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "*.pem": "deny",
      ".npmrc": "deny",
      ".pypirc": "deny",
      "secrets/*": "deny",
      "**/secrets/*": "deny",
      ".aws/*": "deny",
      "**/.aws/*": "deny",
      ".ssh/*": "deny",
      "**/.ssh/*": "deny",
      ".gnupg/*": "deny",
      "**/.gnupg/*": "deny",
      "id_rsa": "deny",
      "id_rsa.*": "deny",
      "id_ed25519": "deny",
      "id_ed25519.*": "deny"
    }
  }
}
