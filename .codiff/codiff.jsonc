{
  "$schema": "https://raw.githubusercontent.com/nkzw-tech/codiff/main/src/config/codiff-config.schema.json",
  "keymap": {
    "closeSearch": "Escape",
    "commandBar": "Mod+k",
    "diffSearch": "Mod+f",
    "discardComment": "Escape",
    "fileFilter": "Mod+p",
    "nextHunk": ["Ctrl+]", "Mod+]", "j"],
    "nextSearchMatch": "Enter",
    "openFile": "Mod+k",
    "prevHunk": ["Ctrl+[", "Mod+[", "k"],
    "prevSearchMatch": "Shift+Enter",
    "shortcutsHelp": "Shift+?",
    "submitComment": "Mod+Enter",
    "toggleSidebar": "Mod+b",
    "toggleWordWrap": "Alt+z",
  },
  "settings": {
    "agentBackend": "codex",
    "codeFontFamily": "JetBrains Mono NL",
    "codeFontSize": 17,
    "copyCommentsOnClose": false,
    "diffStyle": "unified",
    "editorCommand": "",
    "openAIModel": "gpt-5.3-codex-spark",
    "showOutdated": false,
    "showWhitespace": false,
    "theme": "system",
    "walkthroughOrder": "keys",
    "wordWrap": false,
  },
}
